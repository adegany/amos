{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amos.local/schemas/evidence_record.schema.json",
  "title": "AMOS EvidenceRecord",
  "type": "object",
  "required": ["evidence_id", "schema_version", "source_type", "source_ref", "payload", "captured_at", "checksum", "access_policy", "scope"],
  "properties": {
    "evidence_id": { "type": "string" },
    "schema_version": { "const": "amos.v1" },
    "source_type": { "type": "string" },
    "source_ref": { "type": "string" },
    "payload": {},
    "captured_at": { "type": "string" },
    "checksum": { "type": "string" },
    "access_policy": { "$ref": "access_policy.schema.json" },
    "scope": { "$ref": "scope.schema.json" }
  }
}
