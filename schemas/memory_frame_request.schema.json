{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amos.local/schemas/memory_frame_request.schema.json",
  "title": "AMOS MemoryFrameRequest",
  "type": "object",
  "required": ["need", "purpose"],
  "properties": {
    "need": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "depth": { "enum": ["orientation", "working_frame", "focused", "evidence", "supporting"] },
    "task_context": {
      "type": "object",
      "properties": {
        "human_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "project_thread_id": { "type": "string", "minLength": 1 },
        "conversation_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "scope": { "$ref": "scope.schema.json" },
    "requester": { "type": "string", "minLength": 1 },
    "target_processor": { "type": "string", "minLength": 1 },
    "token_or_byte_budget": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        {
          "type": "object",
          "properties": {
            "tokens": { "type": "integer", "minimum": 1 },
            "bytes": { "type": "integer", "minimum": 1 }
          },
          "oneOf": [
            { "required": ["tokens"] },
            { "required": ["bytes"] }
          ],
          "additionalProperties": false
        }
      ]
    },
    "run_policy": { "type": "boolean" }
  },
  "additionalProperties": false
}
